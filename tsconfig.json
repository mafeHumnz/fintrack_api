{
  "compilerOptions": {
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "nodenext",

    "target": "es2023",

    "types": ["node"],

    "strict": true,

    "allowJs": true,

    "jsx": "react-jsx",

    "esModuleInterop": true,

    "ignoreDeprecations": "6.0",

    "sourceMap": true,

    "skipLibCheck": true,

    "isolatedModules": true,

    //"verbatimModuleSyntax": true
  },

  "include": [
    "src/**/*",
    "prisma.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}